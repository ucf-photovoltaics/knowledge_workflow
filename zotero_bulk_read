def get_collection_map():
    # Fetch all collections in the group
    collections = zot.collections()
    collection_dict = {col['data']['name']: col['key'] for col in collections}
    
    return collection_dict

my_collections = get_collection_map()

def search_zotero_collection(query, collection_id=None, limit=100):
    if collection_id:
        print(f"Searching for '{query}' inside collection {collection_id}...")
        # Search specifically within the items of one collection
        results = zot.collection_items(collection_id, q=query, limit=limit)
    else:
        print(f"Searching for '{query}' in the entire library...")
        results = zot.items(q=query, limit=limit)
        
    return results

def all_collections_to_dataframe(collection_map):
    all_rows = []
    
    for name, c_id in collection_map.items():
        print(f"Processing collection: {name}...")
        
        # Get all items for this specific collection
        items = zot.everything(zot.collection_items(c_id))
        
        for item in items:
            # Skip attachments (PDFs) and notes to focus on the papers
            if item['data'].get('itemType') in ['attachment', 'note']:
                continue
                
            data = item['data']
            
            all_rows.append({
                'collection_name': name,
                'collection_id': c_id,
                'title': data.get('title'),
                'doi': data.get('DOI'),
                'abstract': data.get('abstractNote'),
                'item_key': item['key'],
                'date': data.get('date'),
                'cite_number': None  # Placeholder for SerpAPI/Scholar data
            })
            
    return pd.DataFrame(all_rows)
