LIBRARY_ID = '2189702'
LIBRARY_TYPE = 'group' # or 'group'
API_KEY = 'Get your own API key'
zot = Zotero(LIBRARY_ID, LIBRARY_TYPE, API_KEY)

def get_library_dictionary():
    # Retrieve all items (Note: zot.everything() handles pagination for you)
    all_items = zot.everything(zot.items())
    library_dict = {}

    for item in all_items:
        data = item['data']
        # Use DOI or Title as a key for easy deduplication checks
        key = data.get('title')
        if key:
            library_dict[key.lower()] = item
            
    return library_dict

